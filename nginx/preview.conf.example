# 说明：本文件为静态参考示例（规划/教学用途，非运行时配置）。
# 运行时请使用 nginx/preview.conf.template（由官方 Nginx 镜像通过 envsubst 渲染，
# 仅替换 ${NGINX_LISTEN_WEB} / ${NGINX_LISTEN_ADMIN} / ${NGINX_LISTEN_API}）。
# 两者逻辑一致：80/8081/8082 三端口 -> web/admin/api，全站 noindex。
#
# 以下为渲染后的可读参考（端口已写死为默认 80/8081/8082，无真实 IP/域名/证书）。

server_tokens off;

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name _;
    add_header X-Robots-Tag "noindex, nofollow, noarchive" always;
    client_max_body_size 20m;
    location / {
        proxy_pass http://web:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 60s;
    }
}

server {
    listen 8081;
    server_name _;
    add_header X-Robots-Tag "noindex, nofollow, noarchive" always;
    client_max_body_size 20m;
    location / {
        proxy_pass http://admin:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 60s;
    }
}

server {
    listen 8082;
    server_name _;
    add_header X-Robots-Tag "noindex, nofollow, noarchive" always;
    client_max_body_size 20m;
    location / {
        proxy_pass http://api:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 60s;
    }
}
