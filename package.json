{
  "name": "emoji-platform",
  "version": "0.1.0",
  "private": true,
  "description": "A long-term maintainable global Emoji platform",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @emoji-platform/web dev",
    "dev:admin": "pnpm --filter @emoji-platform/admin dev",
    "dev:api": "pnpm --filter @emoji-platform/api start:dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @emoji-platform/api prisma:generate",
    "db:migrate": "pnpm --filter @emoji-platform/api prisma:migrate",
    "db:seed": "pnpm --filter @emoji-platform/api prisma:seed",
    "db:studio": "pnpm --filter @emoji-platform/api prisma:studio",
    "import:emoji": "tsx scripts/import-unicode-data/import-emojis.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "prisma",
      "bcrypt",
      "esbuild",
      "@prisma/client"
    ],
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "tsx": "^4.23.0"
  }
}