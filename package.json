{
  "name": "emoji-platform",
  "version": "0.1.0",
  "private": true,
  "description": "A long-term maintainable global Emoji platform",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @emoji-platform/web dev",
    "dev:admin": "pnpm --filter @emoji-platform/admin dev",
    "dev:api": "pnpm --filter @emoji-platform/api start:dev",
    "build": "pnpm --filter @emoji-platform/types build && pnpm --filter @emoji-platform/shared build && pnpm --filter @emoji-platform/api build && pnpm --filter @emoji-platform/web build && pnpm --filter @emoji-platform/admin build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @emoji-platform/types build && pnpm --filter @emoji-platform/shared build && pnpm -r typecheck",
    "db:generate": "pnpm --filter @emoji-platform/api prisma:generate",
    "db:migrate": "pnpm --filter @emoji-platform/api prisma:migrate",
    "db:seed": "pnpm --filter @emoji-platform/api prisma:seed",
    "db:studio": "pnpm --filter @emoji-platform/api prisma:studio",
    "import:emoji": "tsx scripts/import-unicode-data/import-emojis.ts",
    "preview:validate": "bash scripts/preview/validate-env.sh",
    "preview:config": "docker compose -f docker-compose.preview.yml -p emoji-platform-preview config",
    "preview:build": "bash scripts/preview/build.sh",
    "preview:up": "bash scripts/preview/up.sh",
    "preview:down": "bash scripts/preview/down.sh",
    "preview:status": "bash scripts/preview/status.sh",
    "preview:logs": "bash scripts/preview/logs.sh",
    "preview:migrate": "bash scripts/preview/migrate.sh",
    "preview:seed": "bash scripts/preview/seed.sh"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "tsx": "^4.23.0"
  }
}
