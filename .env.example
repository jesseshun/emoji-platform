# Environment

NODE_ENV=development

# Web
WEB_PORT=3000

# Admin
ADMIN_PORT=3001

# API
API_PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emoji_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=emoji_platform

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
# Phase 6A: search infrastructure planning only. Meilisearch is NOT connected yet.
# These values may be empty; empty values MUST NOT cause a startup failure.
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=change_me
# Phase 6A placeholder for the API key name used by the search provider (Phase 6B).
MEILISEARCH_API_KEY=
# Index prefix for Phase 6B search indexes (not used in Phase 6A).
MEILISEARCH_INDEX_PREFIX=emoji_platform

# Search provider (Phase 6A)
# Active search provider. Default `database` keeps current behavior.
# `meilisearch` is planned for Phase 6B and, when selected in Phase 6A without a
# real connection, safely falls back to the database provider.
SEARCH_PROVIDER=database

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# URLs
SITE_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
