# Environment

NODE_ENV=development

# Web
WEB_PORT=3000

# Admin
ADMIN_PORT=3001

# API
API_PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emoji_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=emoji_platform

# Redis
REDIS_URL=redis://localhost:6379

# ─── Meilisearch (Phase 6B) ──────────────────────────
# 搜索引擎。默认不启用：SEARCH_PROVIDER=database 时不会连接 Meilisearch。
# 仅当 SEARCH_PROVIDER=meilisearch 时才会尝试连接；缺失变量不会造成启动失败。
# 以下均为示例值，绝非真实密钥；生产环境请替换为强随机密钥并通过 .env 注入。
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev_meili_master_key
MEILISEARCH_INDEX_PREFIX=emoji_platform

# 统一搜索索引名 = {MEILISEARCH_INDEX_PREFIX}_search（即 emoji_platform_search）。
# 单索引 + locale 字段，包含 emoji / category / topic / article 的 published 内容。
# 不索引 Asset；不索引 draft / archived；不索引任何 admin 内容。

# Search provider
# 当前搜索 provider。默认 database 保留现有数据库搜索行为。
# 设为 meilisearch 时启用 Meilisearch；若 Meilisearch 不可用，自动 fallback 到 database。
SEARCH_PROVIDER=database

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# URLs
SITE_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
