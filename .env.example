# ============================================================================
# Emoji Platform — Local Development Environment Variables (EXAMPLE ONLY)
# ----------------------------------------------------------------------------
# 这是本地开发模板，可提交到仓库。
# 真实文件为 .env / .env.local（已在 .gitignore 忽略，绝不提交）。
# 所有示例值均为占位，绝非真实密钥、真实 IP、真实域名、GitHub PAT。
# ============================================================================

# ─── Environment ──────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=development

# ─── Web / Admin / API 端口 ──────────────────────────────────────────────
WEB_PORT=3000
ADMIN_PORT=3001
API_PORT=4000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emoji_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=emoji_platform

# ─── Redis（如被依赖） ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Meilisearch (Phase 6B) ──────────────────────────────────────────────
# 搜索引擎。默认不启用：SEARCH_PROVIDER=database 时不会连接 Meilisearch。
# 仅当 SEARCH_PROVIDER=meilisearch 时才会尝试连接；缺失变量不会造成启动失败。
# 以下均为示例值，绝非真实密钥；生产/预览环境请替换为强随机密钥。
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev_meili_master_key
MEILISEARCH_INDEX_PREFIX=emoji_platform
# 统一搜索索引名 = {MEILISEARCH_INDEX_PREFIX}_search（即 emoji_platform_search）。
SEARCH_PROVIDER=database

# ─── JWT ─────────────────────────────────────────────────────────────────
# 本地开发可用占位值；预览/生产必须使用强随机值（如 `openssl rand -base64 32`）。
# production/preview 缺失 JWT_SECRET 将导致 API 启动失败（fail-fast）。
JWT_SECRET=dev_local_change_me_do_not_ship
JWT_EXPIRES_IN=7d

# ─── URLs（本地开发默认 localhost） ──────────────────────────────────────
SITE_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# ─── Phase 7B：CORS / Cookie / Preview 安全变量（本地开发默认值） ──────────
# 本地开发留空即可，API（main.ts）会自动回退到 localhost:3000 / localhost:3001。
# Preview/Production 通过 .env.preview / .env.production 显式配置。
CORS_ORIGIN=
ADMIN_ALLOWED_ORIGINS=
WEB_BASE_URL=
ADMIN_BASE_URL=
API_BASE_URL=

# Cookie 安全：本地开发默认 false（HTTP）；HTTPS 正式环境应设 true。
COOKIE_SECURE=false
# Cookie domain：留空时由浏览器按当前 host 处理（IP+端口访问应留空）。
COOKIE_DOMAIN=

# 限流：如项目已支持则接入；当前仅模板说明，未强制实现。
RATE_LIMIT_ENABLED=false

# Preview 全站 noindex：本地开发默认 false（可被搜索引擎收录用于调试）。
PREVIEW_NOINDEX=false
