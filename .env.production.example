# ============================================================================
# Emoji Platform — Production Environment Variables (EXAMPLE ONLY)
# ----------------------------------------------------------------------------
# 本文件是占位模板，可提交到仓库。
# 真实文件为 .env.production（已在 .gitignore 忽略，绝不提交）。
# 本文件不含任何真实值、真实密码、真实 token、真实服务器 IP、GitHub PAT。
# 所有 <...> 占位符需在正式服务器上替换为项目自身的强随机值 / 已备案域名。
# ============================================================================

# ─── Environment ──────────────────────────────────────────────────────────
# 容器内 NODE_ENV 由 Dockerfile runner 阶段固定为 production。
NODE_ENV=production
APP_ENV=production

# ─── Web / Admin / API 端口（容器内部端口，由 Nginx 反代，不直接暴露公网） ───
WEB_PORT=3000
ADMIN_PORT=3001
API_PORT=4000

# ─── URLs（占位，部署时替换为已备案正式域名；不写真实值） ──────────────────
# 路线 A（海外/免备案）：www.example.com / admin.example.com / api.example.com
# 路线 B（国内/已备案 + CDN）：同上，并接入国内 CDN
NEXT_PUBLIC_SITE_URL=https://www.example.com
NEXT_PUBLIC_ADMIN_URL=https://admin.example.com
NEXT_PUBLIC_API_URL=https://api.example.com

SITE_URL=https://www.example.com
ADMIN_URL=https://admin.example.com
API_URL=https://api.example.com

# ─── CORS / Cookie / 安全变量 ────────────────────────────────────────────
# 生产 CORS：显式列出已备案的 web / admin 来源（多 origin 逗号分隔、自动 trim）。
CORS_ORIGIN=https://www.example.com,https://admin.example.com
WEB_BASE_URL=https://www.example.com
ADMIN_BASE_URL=https://admin.example.com
API_BASE_URL=https://api.example.com
ADMIN_ALLOWED_ORIGINS=https://admin.example.com

# 生产 Cookie：HTTPS 必须 secure=true；domain 按正式域名配置（不写死、不入库）。
COOKIE_SECURE=true
COOKIE_DOMAIN=example.com

# 限流：如项目已支持则接入；当前仅模板说明。
RATE_LIMIT_ENABLED=true

# 生产不做全站 noindex（正式 SEO 开放 sitemap / robots / 站长平台）。
PREVIEW_NOINDEX=false

# ─── Database (PostgreSQL，独立生产库) ───────────────────────────────────
POSTGRES_USER=emoji_prod
POSTGRES_PASSWORD=<PROD_POSTGRES_STRONG_PASSWORD>
POSTGRES_DB=emoji_platform_prod
DATABASE_URL=postgresql://emoji_prod:<PROD_POSTGRES_STRONG_PASSWORD>@postgres:5432/emoji_platform_prod

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Meilisearch ──────────────────────────────────────────────────────────
SEARCH_PROVIDER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=<PROD_MEILI_STRONG_KEY>
MEILISEARCH_INDEX_PREFIX=emoji_platform_prod
# 统一搜索索引名 = {MEILISEARCH_INDEX_PREFIX}_search

# ─── JWT（占位，部署时替换为 ≥32 字节随机值；不入库、不写文档） ───────────────
# 生成示例（仅在服务器执行，结果写进真实 .env.production，不提交）：
#   openssl rand -base64 32
# 注意：production 缺失 JWT_SECRET 将导致 API 启动失败（fail-fast），不可用占位值。
JWT_SECRET=<PROD_JWT_STRONG_RANDOM_32PLUS_BYTES>
JWT_EXPIRES_IN=7d

# ─── 说明 ──────────────────────────────────────────────────────────────────
# 1. 本文件所有 <...> 均为占位，部署者在服务器生成真实 .env.production 时替换。
# 2. .env.production 不提交（.gitignore 已忽略）。
# 3. 生产密钥独立于 preview，不得复用。
# 4. 不写 GitHub PAT、不写真实服务器 IP、不写真实密码/token 到本文件以外的任何文件。
# 5. GitHub PAT 仅可一次性用于 git push，不得写入 remote URL / git config / 任何文件。
