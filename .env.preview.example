# ============================================================================
# Emoji Platform — Preview Environment Variables (EXAMPLE ONLY)
# ----------------------------------------------------------------------------
# 本文件是占位模板，可提交到仓库。
# 真实文件为 .env.preview（已在 .gitignore 忽略，绝不提交）。
# 本文件不含任何真实值、真实密码、真实 token、真实服务器 IP、GitHub PAT。
# 所有 <...> 占位符需在部署服务器上替换为项目自身的强随机值 / 真实域名 / IP。
# ============================================================================

# ─── Environment ──────────────────────────────────────────────────────────
# 容器内 NODE_ENV 由 Dockerfile runner 阶段固定为 production；
# APP_ENV=preview 标注这是预览环境（用于 JWT_SECRET 强制校验、cookie secure 默认等）。
NODE_ENV=production
APP_ENV=preview

# ─── Web / Admin / API 端口（容器内部端口，由 Nginx 反代，不直接暴露公网） ───
WEB_PORT=3000
ADMIN_PORT=3001
API_PORT=4000

# ─── URLs（占位，部署时替换为 preview 子域或服务器 IP；不写真实值） ─────────
# 子域方式（推荐，但受未备案域名被拦截风险制约）：
NEXT_PUBLIC_SITE_URL=https://preview.example.com
NEXT_PUBLIC_ADMIN_URL=https://admin-preview.example.com
NEXT_PUBLIC_API_URL=https://api-preview.example.com

# 若仅用 IP + 端口（方案 A，与当前 CORS 回退兼容最稳），改为：
# NEXT_PUBLIC_SITE_URL=http://SERVER_IP:3000
# NEXT_PUBLIC_ADMIN_URL=http://SERVER_IP:3001
# NEXT_PUBLIC_API_URL=http://SERVER_IP:4000

# 服务端（admin/web 服务端 fetch）使用：
SITE_URL=https://preview.example.com
ADMIN_URL=https://admin-preview.example.com
API_URL=https://api-preview.example.com

# ─── Phase 7B：CORS / Cookie / Preview 安全变量（已实现，由 main.ts 读取） ──
# CORS_ORIGIN 逗号分隔多 origin；ADMIN_ALLOWED_ORIGINS 限定 Admin 来源。
# WEB_BASE_URL / ADMIN_BASE_URL / API_BASE_URL 也会被并入允许来源。
# 支持多 origin、自动 trim、忽略空值；全部为空时 API 回退到 localhost（仅适合本地）。
CORS_ORIGIN=https://preview.example.com,https://admin-preview.example.com
# 若用 IP+端口：CORS_ORIGIN=http://SERVER_IP:3000,http://SERVER_IP:3001
WEB_BASE_URL=https://preview.example.com
ADMIN_BASE_URL=https://admin-preview.example.com
API_BASE_URL=https://api-preview.example.com
ADMIN_ALLOWED_ORIGINS=https://admin-preview.example.com

# Cookie：HTTPS 访问设 true；若仅 HTTP（如 IP+端口）联调可临时设 false。
COOKIE_SECURE=true
# COOKIE_DOMAIN：子域访问时按实际域名配置（如 preview.example.com）；
# IP+端口访问应留空。绝不写死正式域名、绝不入库。
COOKIE_DOMAIN=preview.example.com

# 限流：如项目已支持则接入；当前仅模板说明。
RATE_LIMIT_ENABLED=false

# Preview 全站 noindex：建议 true（Nginx 层 / robots 层双保险，详见部署文档）。
PREVIEW_NOINDEX=true

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
# 预览库独立，勿与生产/本地库混用。密码为占位，部署时替换为强随机值。
POSTGRES_USER=emoji_preview
POSTGRES_PASSWORD=<PREVIEW_POSTGRES_STRONG_PASSWORD>
POSTGRES_DB=emoji_platform_preview
DATABASE_URL=postgresql://emoji_preview:<PREVIEW_POSTGRES_STRONG_PASSWORD>@postgres:5432/emoji_platform_preview

# ─── Redis（如被依赖；低配预览可评估是否必需） ──────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Meilisearch（Phase 6B） ──────────────────────────────────────────────
# 低配预览可设 SEARCH_PROVIDER=database 关闭 Meilisearch，使用数据库 fallback。
SEARCH_PROVIDER=database
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=<PREVIEW_MEILI_STRONG_KEY>
MEILISEARCH_INDEX_PREFIX=emoji_platform_preview
# 统一搜索索引名 = {MEILISEARCH_INDEX_PREFIX}_search

# ─── JWT（占位，部署时替换为 ≥32 字节随机值；不入库、不写文档） ───────────────
# 生成示例（仅在服务器执行，结果写进真实 .env.preview，不提交）：
#   openssl rand -base64 32
JWT_SECRET=<PREVIEW_JWT_STRONG_RANDOM_32PLUS_BYTES>
JWT_EXPIRES_IN=7d

# ─── 说明 ──────────────────────────────────────────────────────────────────
# 1. 本文件所有 <...> 均为占位，部署者在服务器生成真实 .env.preview 时替换。
# 2. .env.preview 不提交（.gitignore 已忽略）。
# 3. preview 密钥独立于生产，不得复用于 production。
# 4. 不写 GitHub PAT、不写真实服务器 IP、不写真实密码/token 到本文件以外的任何文件。
# 5. GitHub PAT 仅可一次性用于 git push，不得写入 remote URL / git config / 任何文件。
